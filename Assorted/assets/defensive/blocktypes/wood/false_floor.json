{
	code: "false_floor",
	class: "CollapsingBlock",
	variantgroups: [
    { code: "cover",  states: [ "cobblestone","stonebricks" ] },
    { code: "material", loadFromProperties: "block/rock" },    
    ],
	behaviors: [{name: "NeedSides", properties: { applicableMaterials: ["Soil", "Wood", "Stone", "Ore", "Metal", "Mantle", "Ceramic", "Brick", "Other"]} }],
	creativeinventory: { "general": ["*"], "terrain": ["*"] },
	shape: { base: "block/wood/false_floor" },		
    blockmaterial: "Stone",
	texturesByType: {    	
        "*-cobblestone-*": {
			"wood": { base: "game:block/plant/bamboo/stem-brown" },
			"camo": { base: "game:block/stone/cobblestone/{material}1" }
        },
        "*-stonebricks-*": {
			"wood": { base: "game:block/plant/bamboo/stem-brown" },
			"camo": { base: "game:block/stone/brick/{material}1" }
        },
	},
	attributes: {
		preventsDecay: true,
		allowUnstablePlacement: true
	},    
    sidesolid: {
		all: false , top: true 
	},
	sideopaque: {
		all: false , top: true 
	},
	replaceable: 600,
	resistance: 0.4,
	selectionBox: { x1: 0, y1: 0.6875, z1: 0, x2: 1, y2: 1, z2: 1 },
	collisionbox: { x1: 0, y1: 0.6875, z1: 0, x2: 1, y2: 1, z2: 1 },
	sounds: {
		"walk": "game:walk/wood",
		"break":"game:effect/rockslide",
